# NVIDIA NIM API Key (for Nemotron Ultra & DeepSeek models)
NVIDIA_API_KEY=your_nvidia_nim_api_key

# Groq API Key (for fast inference & Whisper STT)
GROQ_API_KEY=your_groq_api_key

# Indian Kanoon API Token (for legal case search)
INDIAN_KANOON_TOKEN=your_indian_kanoon_token

# Encryption key for PII tokenization (auto-generated on first run if blank)
ENCRYPTION_KEY=

# ChromaDB persistent storage path (relative to backend root)
CHROMA_PERSIST_DIR=./chroma_db

# Server settings
HOST=0.0.0.0
PORT=8000
